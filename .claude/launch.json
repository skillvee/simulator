{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "port": 3000,
      "autoPort": false,
      "env": {
        "NEXT_PUBLIC_SKIP_SCREEN_RECORDING": "true",
        "RESOURCE_PIPELINE_V2": "on",
        "NEXT_PUBLIC_RESOURCE_PIPELINE_V2": "on"
      }
    },
    {
      "name": "next-dev-demo-verify",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "next-dev-verify",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3100"],
      "port": 3100,
      "autoPort": false,
      "env": {
        "NEXT_PUBLIC_SKIP_SCREEN_RECORDING": "true"
      }
    },
    {
      "name": "prisma-studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["prisma", "studio"],
      "port": 5555
    }
  ]
}
