generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  role                   UserRole                @default(USER)
  preferredLanguage      String                  @default("en")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  dataDeleteRequestedAt  DateTime?
  accounts               Account[]
  assessments            Assessment[]
  createdScenarios       Scenario[]              @relation("CreatedScenarios")
  sessions               Session[]
  clientErrors           ClientError[]
  simulationCreationLogs SimulationCreationLog[]
  videoAssessments       VideoAssessment[]
  apiRequestLogs         ApiRequestLog[]
}

model Scenario {
  id                     String                  @id @default(cuid())
  name                   String
  companyName            String
  companyDescription     String
  taskDescription        String
  repoUrl                String?
  techStack              String[]
  isPublished            Boolean                 @default(false)
  isChallenge            Boolean                 @default(false)
  challengeTagline       String?
  language               String                  @default("en")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  createdById            String?
  targetLevel            String                  @default("mid")
  simulationDepth        String                  @default("medium") // "short" | "medium" | "long"
  archetypeId            String?
  repoSpec               Json?
  resources              Json?
  assessments            Assessment[]
  coworkers              Coworker[]
  archetype              Archetype?              @relation(fields: [archetypeId], references: [id])
  createdBy              User?                   @relation("CreatedScenarios", fields: [createdById], references: [id])
  simulationCreationLogs SimulationCreationLog[]
}

model Coworker {
  id            String         @id @default(cuid())
  scenarioId    String
  name          String
  role          String
  personaStyle  String
  knowledge     Json
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  voiceName     String?
  personality   Json?
  conversations Conversation[]
  scenario      Scenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model Assessment {
  id                     String              @id @default(cuid())
  userId                 String
  scenarioId             String
  status                 AssessmentStatus    @default(WELCOME)
  startedAt              DateTime            @default(now())
  workingStartedAt       DateTime?
  completedAt            DateTime?
  report                 Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  codeReview             Json?
  supersededBy           String?
  targetLevel            String?

  reviewedAt             DateTime?
  repoUrl                String?
  repoStatus             String?             @default("pending")
  scenario               Scenario            @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiCalls               AssessmentApiCall[]
  logs                   AssessmentLog[]
  conversations          Conversation[]
  recordings             Recording[]
  clientErrors           ClientError[]
  voiceSessions          VoiceSession[]
  videoAssessment        VideoAssessment?
  apiRequestLogs         ApiRequestLog[]
  candidateEvents        CandidateEvent[]

  @@index([userId])
  @@index([scenarioId, userId])
}

model Conversation {
  id           String     @id @default(cuid())
  assessmentId String
  coworkerId   String?
  type         String
  transcript   Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  coworker     Coworker?  @relation(fields: [coworkerId], references: [id])
}

model Recording {
  id           String             @id @default(cuid())
  assessmentId String
  type         String
  storageUrl   String
  startTime    DateTime
  endTime      DateTime?
  analysis     Json?
  createdAt    DateTime           @default(now())
  assessment   Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  segments     RecordingSegment[]

  @@index([assessmentId])
}

model RecordingSegment {
  id              String           @id @default(cuid())
  recordingId     String
  segmentIndex    Int
  startTime       DateTime
  endTime         DateTime?
  status          String           @default("recording")
  chunkPaths      String[]
  screenshotPaths String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  recording       Recording        @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  analysis        SegmentAnalysis?
}

model SegmentAnalysis {
  id                  String           @id @default(cuid())
  segmentId           String           @unique
  activityTimeline    Json?
  toolUsage           Json?
  stuckMoments        Json?
  totalActiveTime     Int?
  totalIdleTime       Int?
  focusScore          Int?
  aiAnalysis          Json?
  analyzedAt          DateTime         @default(now())
  screenshotsAnalyzed Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  segment             RecordingSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
}

model VideoAssessment {
  id                String                   @id @default(cuid())
  candidateId       String
  videoUrl          String
  status            VideoAssessmentStatus    @default(PENDING)
  createdAt         DateTime                 @default(now())
  completedAt       DateTime?
  assessmentId      String?                  @unique
  lastFailureReason String?
  retryCount        Int                      @default(0)
  isSearchable      Boolean                  @default(true)
  embeddings        CandidateEmbedding?
  scores            DimensionScore[]
  assessment        Assessment?              @relation(fields: [assessmentId], references: [id])
  candidate         User                     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  apiCalls          VideoAssessmentApiCall[]
  logs              VideoAssessmentLog[]
  summary           VideoAssessmentSummary?

  @@index([candidateId])
  @@index([status])
  @@index([assessmentId])
}

model DimensionScore {
  id                  String          @id @default(cuid())
  assessmentId        String
  dimension           String
  score               Int
  observableBehaviors String
  timestamps          Json
  trainableGap        Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  confidence          String          @default("medium")
  rationale           String?
  assessment          VideoAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, dimension])
  @@index([assessmentId])
}

model VideoAssessmentSummary {
  id             String          @id @default(cuid())
  assessmentId   String          @unique
  overallSummary String
  rawAiResponse  Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assessment     VideoAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentLog {
  id           String                 @id @default(cuid())
  assessmentId String
  eventType    AssessmentLogEventType
  timestamp    DateTime               @default(now())
  durationMs   Int?
  metadata     Json?
  traceId      String?
  assessment   Assessment             @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([timestamp])
  @@index([assessmentId, timestamp])
  @@index([traceId])
}

model AssessmentApiCall {
  id                String     @id @default(cuid())
  assessmentId      String
  requestTimestamp  DateTime   @default(now())
  responseTimestamp DateTime?
  durationMs        Int?
  promptText        String
  promptTokens      Int?
  responseText      String?
  responseTokens    Int?
  modelVersion      String
  statusCode        Int?
  errorMessage      String?
  stackTrace        String?
  modelUsed         String?
  promptType        String?
  promptVersion     String?
  tokenCount        Int?
  traceId           String?
  assessment        Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([requestTimestamp])
  @@index([assessmentId, requestTimestamp])
  @@index([traceId])
}

model VideoAssessmentLog {
  id                String                 @id @default(cuid())
  videoAssessmentId String
  eventType         AssessmentLogEventType
  timestamp         DateTime               @default(now())
  durationMs        Int?
  metadata          Json?
  videoAssessment   VideoAssessment        @relation(fields: [videoAssessmentId], references: [id], onDelete: Cascade)

  @@index([videoAssessmentId])
  @@index([timestamp])
  @@index([videoAssessmentId, timestamp])
}

model VideoAssessmentApiCall {
  id                String          @id @default(cuid())
  videoAssessmentId String
  requestTimestamp  DateTime        @default(now())
  responseTimestamp DateTime?
  durationMs        Int?
  promptText        String
  promptTokens      Int?
  responseText      String?
  responseTokens    Int?
  modelVersion      String
  statusCode        Int?
  errorMessage      String?
  stackTrace        String?
  videoAssessment   VideoAssessment @relation(fields: [videoAssessmentId], references: [id], onDelete: Cascade)

  @@index([videoAssessmentId])
  @@index([requestTimestamp])
  @@index([videoAssessmentId, requestTimestamp])
}

/// Role family grouping (e.g., Engineering, Product, Sales)
/// Each family has its own set of role-specific dimensions and archetypes
model RoleFamily {
  id          String                @id @default(cuid())
  slug        String                @unique
  name        String
  description String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  archetypes  Archetype[]
  redFlags    RedFlag[]
  dimensions  RoleFamilyDimension[]
}

/// Assessment dimension definition (e.g., "Technical Execution", "Communication")
/// Dimensions can be universal (isUniversal=true) or role-family-specific
model Dimension {
  id               String                @id @default(cuid())
  slug             String                @unique
  name             String
  description      String
  isUniversal      Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  archetypeWeights ArchetypeWeight[]
  roleFamilies     RoleFamilyDimension[]
  rubricLevels     RubricLevel[]
  seniorityGates   SeniorityGate[]
}

/// Join table linking role families to dimensions with ordering
model RoleFamilyDimension {
  id           String     @id @default(cuid())
  roleFamilyId String
  dimensionId  String
  sortOrder    Int        @default(0)
  dimension    Dimension  @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  roleFamily   RoleFamily @relation(fields: [roleFamilyId], references: [id], onDelete: Cascade)

  @@unique([roleFamilyId, dimensionId])
}

/// Rubric level definition with behavioral anchors
/// Each dimension has 4 levels (1-4), with optional role-family-specific overrides
/// When roleFamilyId is null, this is the default rubric for the dimension.
/// When roleFamilyId is set, this overrides the default for that role family.
model RubricLevel {
  id           String    @id @default(cuid())
  dimensionId  String
  roleFamilyId String?
  level        Int
  label        String
  pattern      String
  evidence     Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  dimension    Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([dimensionId, roleFamilyId, level])
  @@index([dimensionId])
  @@index([dimensionId, level])
}

/// Role archetype within a role family (e.g., "Frontend Engineer" within Engineering)
model Archetype {
  id             String            @id @default(cuid())
  roleFamilyId   String
  slug           String            @unique
  name           String
  description    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  roleFamily     RoleFamily        @relation(fields: [roleFamilyId], references: [id], onDelete: Cascade)
  weights        ArchetypeWeight[]
  scenarios      Scenario[]
  seniorityGates SeniorityGate[]
}

/// Weight for a dimension within an archetype
model ArchetypeWeight {
  id          String    @id @default(cuid())
  archetypeId String
  dimensionId String
  weight      Float
  archetype   Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([archetypeId, dimensionId])
}

/// Seniority gate: minimum score per dimension per seniority level for an archetype
model SeniorityGate {
  id             String    @id @default(cuid())
  archetypeId    String
  dimensionId    String
  seniorityLevel String
  minScore       Int
  archetype      Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  dimension      Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([archetypeId, dimensionId, seniorityLevel])
}

/// Red flag definitions per role family
/// Binary indicators that are always surfaced regardless of scores
model RedFlag {
  id           String     @id @default(cuid())
  roleFamilyId String
  slug         String
  name         String
  description  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  roleFamily   RoleFamily @relation(fields: [roleFamilyId], references: [id], onDelete: Cascade)

  @@unique([roleFamilyId, slug])
}

model CandidateEmbedding {
  id                      String                @id @default(cuid())
  videoAssessmentId       String                @unique
  observableBehaviorsText String
  overallSummaryText      String
  embedding               Unsupported("vector")
  embeddingModel          String                @default("text-embedding-004")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  videoAssessment         VideoAssessment       @relation(fields: [videoAssessmentId], references: [id], onDelete: Cascade)

  @@index([videoAssessmentId])
}

model SimulationCreationLog {
  id             String                   @id @default(cuid())
  userId         String
  status         SimulationCreationStatus @default(STARTED)
  roleTitle      String?
  companyName    String?
  techStack      String[]
  seniorityLevel String?
  archetypeId    String?
  source         String                   @default("guided")
  scenarioId     String?
  failedStep     String?
  errorMessage   String?
  errorDetails   Json?
  createdAt      DateTime                 @default(now())
  completedAt    DateTime?
  scenario       Scenario?                @relation(fields: [scenarioId], references: [id])
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationSteps SimulationGenerationStep[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SimulationGenerationStep {
  id              String                @id @default(cuid())
  creationLogId   String
  stepName        String                // e.g. "parse_jd", "generate_tasks", "generate_coworkers", "generate_resources"
  status          String                @default("started") // started, completed, failed
  modelUsed       String?               // e.g. "gemini-3-flash-preview"
  promptVersion   String?               // e.g. "3.0"
  promptText      String?               // Full prompt sent to AI
  responseText    String?               // Full AI response
  inputData       Json?                 // Structured input passed to the step
  outputData      Json?                 // Parsed/validated output from the step
  durationMs      Int?                  // How long the step took
  attempts        Int                   @default(1) // Number of retry attempts
  errorMessage    String?
  errorDetails    Json?                 // Stack trace, raw error, etc.
  createdAt       DateTime              @default(now())
  completedAt     DateTime?
  creationLog     SimulationCreationLog @relation(fields: [creationLogId], references: [id], onDelete: Cascade)

  @@index([creationLogId])
  @@index([stepName])
}

model ApiRequestLog {
  id           String      @id @default(cuid())
  method       String
  path         String
  statusCode   Int
  durationMs   Int
  assessmentId String?
  userId       String?
  traceId      String?
  errorMessage String?
  requestBody  Json?
  timestamp    DateTime
  createdAt    DateTime    @default(now())
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([assessmentId, timestamp])
}

enum UserRole {
  USER
  ADMIN
  RECRUITER
}

enum AssessmentStatus {
  WELCOME
  WORKING
  COMPLETED
}

enum AssessmentDimension {
  COMMUNICATION
  PROBLEM_SOLVING
  TECHNICAL_KNOWLEDGE
  COLLABORATION
  ADAPTABILITY
  LEADERSHIP
  CREATIVITY
  TIME_MANAGEMENT
}

enum VideoAssessmentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AssessmentLogEventType {
  STARTED
  PROMPT_SENT
  RESPONSE_RECEIVED
  PARSING_STARTED
  PARSING_COMPLETED
  ERROR
  COMPLETED
}

enum SimulationCreationStatus {
  STARTED
  GENERATING
  SAVING
  COMPLETED
  FAILED
}

enum ClientErrorType {
  UNHANDLED_EXCEPTION
  CONSOLE_ERROR
  CONSOLE_WARN
  CONSOLE_LOG
  REACT_BOUNDARY
}

model VoiceSession {
  id               String     @id @default(cuid())
  assessmentId     String
  coworkerId       String
  startTime        DateTime
  endTime          DateTime?
  transcript       Json
  connectionEvents Json
  tokenName        String?
  errorMessage     String?
  durationMs       Int?
  createdAt        DateTime   @default(now())
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, startTime])
}

model CandidateEvent {
  id           String     @id @default(cuid())
  assessmentId String
  eventType    String
  timestamp    DateTime
  metadata     Json?
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, timestamp])
}

model ClientError {
  id            String          @id @default(cuid())
  assessmentId  String?
  userId        String?
  errorType     ClientErrorType
  message       String
  stackTrace    String?
  componentName String?
  url           String
  timestamp     DateTime
  metadata      Json?
  createdAt     DateTime        @default(now())
  assessment    Assessment?     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId, timestamp])
  @@index([errorType, timestamp])
}

// ─── Prompt Eval System ──────────────────────────────────────────────────────

model EvalRun {
  id            String       @id @default(cuid())
  name          String
  promptVersion String
  model         String
  status        String       @default("running")
  scenarioCount Int
  overallScore  Float?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  results       EvalResult[]

  // Optimization
  optimizationAnalysis Json?
  optimizedPrompt      String?
  optimizedRunId       String?

  @@index([createdAt])
}

model EvalResult {
  id             String   @id @default(cuid())
  evalRunId      String
  scenarioId     String
  scenarioName   String
  category       String

  // Generation
  prompt         String
  userMessage    String
  response       String
  generationMs   Int?

  // Judgments (3 judges as JSON array)
  judgments      Json

  // Aggregated scores (median of 3 judges)
  naturalness    Float?
  roleAccuracy   Float?
  brevity        Float?
  contextAwareness Float?
  infoDiscipline Float?
  aiIsms         Float?
  overallScore   Float?
  flagged        Boolean  @default(false)

  evalRun        EvalRun  @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([evalRunId])
  @@index([scenarioId])
}
